rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "chinlu0322@gmail.com";
    }

    match /resume_data/main {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /experience/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /projects/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
