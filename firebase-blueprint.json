{
  "entities": {
    "user": {
      "title": "User",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "email", "role"]
    },
    "resume": {
      "title": "Resume Data",
      "description": "Global resume content",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "title": { "type": "string" },
        "about": { "type": "string" },
        "location": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "website": { "type": "string" }
      }
    },
    "experience": {
      "title": "Work Experience",
      "type": "object",
      "properties": {
        "company": { "type": "string" },
        "role": { "type": "string" },
        "period": { "type": "string" },
        "description": { "type": "string" },
        "achievements": { "type": "array", "items": { "type": "string" } }
      }
    },
    "project": {
      "title": "Project",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "link": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "user", "description": "User profiles" },
    "/content/resume": { "schema": "resume", "description": "Global resume data" },
    "/experience/{expId}": { "schema": "experience", "description": "Work experiences" },
    "/projects/{projectId}": { "schema": "project", "description": "Projects" }
  }
}
