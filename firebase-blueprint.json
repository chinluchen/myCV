{
  "entities": {
    "resume": {
      "title": "Resume Data",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "title": { "type": "string" },
        "about": { "type": "string" },
        "location": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "website": { "type": "string" }
      }
    },
    "experience": {
      "title": "Experience",
      "type": "object",
      "properties": {
        "company": { "type": "string" },
        "role": { "type": "string" },
        "period": { "type": "string" },
        "description": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/resume_data/main": { "schema": "resume", "description": "Main resume data" },
    "/experience/{id}": { "schema": "experience", "description": "Work experiences" },
    "/projects/{id}": { "schema": "project", "description": "Projects" }
  }
}
